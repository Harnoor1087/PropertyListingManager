<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
</head>
<body>
    <h3>Create New Post</h3>
    <form method="POST" action="/listings">
        <input name="listing[title]" placeholder="Enter Title" type="text">
        <br><br>
        <textarea name="listing[description]" placeholder="Enter description"></textarea>
        <br><br>
        <input type="text" name="listing[image]" placeholder="Enter image URL/link.">
        <br><br>
        <input type="number" name="listing[price]" placeholder="Enter price">
        <br><br>
        <input type="text" name="listing[location]" placeholder="Enter location">
        <br><br>
        <input type="text" name="listing[country]" placeholder="Enter country.">
        <br><br>
        <button>Submit</button>
    </form>
</body>
</html>